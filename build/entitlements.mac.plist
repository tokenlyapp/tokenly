<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTD/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow JIT (required by V8 in Electron). -->
  <key>com.apple.security.cs.allow-jit</key><true/>
  <!-- Required because Babel Standalone evals at runtime in our current CSP.
       Remove this once we precompile the JSX. -->
  <key>com.apple.security.cs.allow-unsafe-dynamic-memory</key><true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key><true/>
  <!-- Allow loading Electron's own dylibs (signed by Apple, not us). -->
  <key>com.apple.security.cs.disable-library-validation</key><true/>
  <!-- Network access for provider API calls. -->
  <key>com.apple.security.network.client</key><true/>
</dict>
</plist>
